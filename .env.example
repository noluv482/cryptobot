# ── Telegram (required) ───────────────────────────────────────────────────────
# Get your bot token from @BotFather and your chat ID from @userinfobot
TG_TOKEN=your_telegram_bot_token_here
TG_CHAT_ID=your_telegram_chat_id_here

# ── Dashboard PIN (required) ──────────────────────────────────────────────────
# Choose any 4-digit PIN — you will need it to unlock the dashboard and save API keys
DASHBOARD_PIN=

# ── Database password (required) ──────────────────────────────────────────────
# Choose any strong password — used internally between the bot and Postgres
DB_PASSWORD=changeme_use_a_strong_password

# ── Kraken API keys (optional) ────────────────────────────────────────────────
# Leave blank to add keys via the dashboard Settings → API Keys panel instead
KRAKEN_KEY=
KRAKEN_SECRET=

# ── Discord webhook (optional) ────────────────────────────────────────────────
# Paste a Discord webhook URL to mirror trade alerts to a Discord channel
DISCORD_WEBHOOK=
